@{
    ViewData["Title"] = "Dashboard";
    ViewData["CurrentStep"] = "Dashboard";
}

<!-- ================= STAFF DASHBOARD ================= -->
<div id="staffDashboard" class="d-none">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3 fw-bold text-dark mb-1">Operations Dashboard</h1>
            <p class="text-muted">Real-time overview of loan origination pipeline and key performance indicators.</p>
        </div>
    </div>

    <!-- KPI Stat Cards -->
    <div class="row g-4 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm card-hover h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 52px; height: 52px; font-size: 1.25rem;">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Total Applications</div>
                        <h3 class="fw-bold text-dark mb-0" id="kpiTotal">0</h3>
                        <span class="text-success small fw-semibold"><i class="fa-solid fa-arrow-up me-1"></i>12% vs last month</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm card-hover h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 52px; height: 52px; font-size: 1.25rem;">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Pending Review</div>
                        <h3 class="fw-bold text-dark mb-0" id="kpiPending">0</h3>
                        <span class="text-warning small fw-semibold"><i class="fa-solid fa-minus me-1"></i>Awaiting action</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm card-hover h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 52px; height: 52px; font-size: 1.25rem;">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Approved This Month</div>
                        <h3 class="fw-bold text-dark mb-0" id="kpiApproved">0</h3>
                        <span class="text-success small fw-semibold"><i class="fa-solid fa-arrow-up me-1"></i>8% increase</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm card-hover h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 52px; height: 52px; font-size: 1.25rem;">
                        <i class="fa-solid fa-hand-holding-dollar"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Disbursed Volume</div>
                        <h3 class="fw-bold text-dark mb-0" id="kpiDisbursed">₹ 0</h3>
                        <span class="text-info small fw-semibold">This quarter</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4 mb-4">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold text-dark m-0">Application Status Distribution</h6>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <canvas id="statusDoughnutChart" style="max-height: 280px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold text-dark m-0">Monthly Application Volume & Approvals</h6>
                </div>
                <div class="card-body">
                    <canvas id="monthlyBarChart" style="max-height: 280px;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Approval Trend + Recent Activity -->
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold text-dark m-0">Approval Rate Trend (6 Months)</h6>
                </div>
                <div class="card-body">
                    <canvas id="approvalTrendChart" style="max-height: 260px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold text-dark m-0">Recent Pipeline Activity</h6>
                    <a href="/Loan" class="btn btn-sm btn-link text-decoration-none">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive border-0">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Application</th>
                                    <th>Customer</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Updated</th>
                                </tr>
                            </thead>
                            <tbody id="recentActivityBody">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ================= CUSTOMER PORTAL DASHBOARD ================= -->
<div id="customerDashboard" class="d-none">
    <!-- Welcome Banner -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="p-4 rounded-4 text-white shadow-sm" style="background: linear-gradient(135deg, var(--secondary-navy) 0%, #1E3A5F 100%);">
                <div class="row align-items-center">
                    <div class="col-md-8 mb-3 mb-md-0">
                        <h2 class="fw-bold mb-1">Welcome Back, Rajesh Kumar!</h2>
                        <p class="text-white-50 mb-0">Track your active loan origination stages, upload validations, or submit new applications below.</p>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <a href="/Loan/Create" class="btn btn-primary px-4 py-2fw-semibold" style="border-radius: var(--radius-md); box-shadow: 0 4px 12px rgba(13,110,253,0.3);">
                            <i class="fa-solid fa-plus me-2"></i> Apply for a Loan
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Loan Progress Tracking -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-spinner text-primary me-2"></i> Active Application Tracking</h6>
                    <span class="badge bg-warning text-dark px-3 py-2 fw-semibold">Under Review</span>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-6 col-md-3">
                            <span class="text-muted small">Application ID</span>
                            <h6 class="fw-bold text-dark mb-0 mt-1">#LOC-9844-32</h6>
                        </div>
                        <div class="col-sm-6 col-md-3">
                            <span class="text-muted small">Requested Amount</span>
                            <h6 class="fw-bold text-primary mb-0 mt-1">₹ 45,00,000</h6>
                        </div>
                        <div class="col-sm-6 col-md-3">
                            <span class="text-muted small">Product Type</span>
                            <h6 class="fw-bold text-dark mb-0 mt-1">Home Purchase Loan</h6>
                        </div>
                        <div class="col-sm-6 col-md-3">
                            <span class="text-muted small">Submission Date</span>
                            <h6 class="fw-bold text-dark mb-0 mt-1">2026-06-24</h6>
                        </div>
                    </div>

                    <!-- Horizontal Stepper Progress -->
                    <div class="position-relative py-3 mt-3">
                        <div class="progress" style="height: 4px; background-color: #E2E8F0;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: 75%;" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="d-flex justify-content-between position-absolute w-100 top-50 translate-middle-y px-1">
                            <div class="text-center">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem;"><i class="fa-solid fa-paper-plane"></i></div>
                                <span class="d-block small fw-semibold text-dark mt-2">Submitted</span>
                            </div>
                            <div class="text-center">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem;"><i class="fa-solid fa-id-card"></i></div>
                                <span class="d-block small fw-semibold text-dark mt-2">KYC Verified</span>
                            </div>
                            <div class="text-center">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem;"><i class="fa-solid fa-gauge-high"></i></div>
                                <span class="d-block small fw-semibold text-dark mt-2">Credit Scored</span>
                            </div>
                            <div class="text-center">
                                <div class="bg-white border border-primary text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem;"><i class="fa-solid fa-signature"></i></div>
                                <span class="d-block small fw-semibold text-primary mt-2">Decisioning</span>
                            </div>
                            <div class="text-center">
                                <div class="bg-white border text-muted rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem;"><i class="fa-solid fa-hand-holding-dollar"></i></div>
                                <span class="d-block small text-muted mt-2">Disbursed</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light py-3 border-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span class="small text-muted"><i class="fa-solid fa-circle-info me-1"></i> Awaiting Underwriter final validation step.</span>
                    <a href="/Document/Upload/9844" class="btn btn-sm btn-outline-primary fw-semibold"><i class="fa-solid fa-upload me-1"></i> Upload Supporting Documents</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Loan Catalog & My Applications Row -->
    <div class="row g-4">
        <!-- Products Quick Catalog -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold text-dark m-0">Eligible Loan Products</h6>
                </div>
                <div class="card-body d-flex flex-column gap-3 p-3">
                    <div class="d-flex align-items-center justify-content-between p-3 border rounded-3 card-hover bg-white">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;"><i class="fa-solid fa-house-chimney"></i></div>
                            <div>
                                <h6 class="fw-bold text-dark mb-0">Home Purchase Loan</h6>
                                <span class="text-muted small">8.5% p.a. • Tenure up to 30 years</span>
                            </div>
                        </div>
                        <a href="/Loan/Create?type=home" class="btn btn-sm btn-primary px-3 fw-semibold">Apply</a>
                    </div>
                    <div class="d-flex align-items-center justify-content-between p-3 border rounded-3 card-hover bg-white">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;"><i class="fa-solid fa-car"></i></div>
                            <div>
                                <h6 class="fw-bold text-dark mb-0">Car Purchase Loan</h6>
                                <span class="text-muted small">9.2% p.a. • Tenure up to 7 years</span>
                            </div>
                        </div>
                        <a href="/Loan/Create?type=car" class="btn btn-sm btn-success text-white px-3 fw-semibold">Apply</a>
                    </div>
                    <div class="d-flex align-items-center justify-content-between p-3 border rounded-3 card-hover bg-white">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;"><i class="fa-solid fa-circle-dollar-to-slot"></i></div>
                            <div>
                                <h6 class="fw-bold text-dark mb-0">Personal Express Loan</h6>
                                <span class="text-muted small">10.5% p.a. • Tenure up to 5 years</span>
                            </div>
                        </div>
                        <a href="/Loan/Create?type=personal" class="btn btn-sm btn-info text-white px-3 fw-semibold">Apply</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- History Ledger -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold text-dark m-0">My Applications Ledger</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive border-0">
                        <table class="table align-middle m-0">
                            <thead>
                                <tr>
                                    <th>Loan Reference</th>
                                    <th>Amount</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span class="fw-bold text-dark">#LOC-9844-32</span></td>
                                    <td>₹ 45,00,000</td>
                                    <td>Home Loan</td>
                                    <td><span class="badge bg-warning text-dark">Under Review</span></td>
                                </tr>
                                <tr>
                                    <td><span class="fw-bold text-muted">#LOC-8212-09</span></td>
                                    <td>₹ 15,00,000</td>
                                    <td>Car Loan</td>
                                    <td><span class="badge bg-success">Approved</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/charts.js"></script>
    <script src="~/js/dashboard.js"></script>
}

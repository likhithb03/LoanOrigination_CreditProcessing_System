@{
    ViewData["Title"] = "System Settings";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">System Configuration</h1>
        <p class="text-muted">Manage global portal settings, notifications, and system behaviour.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6 col-lg-4">
        <a href="/Settings/ScoringRules" class="text-decoration-none">
            <div class="card border-0 shadow-sm card-hover h-100">
                <div class="card-body py-4 text-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px; font-size: 1.5rem;">
                        <i class="fa-solid fa-sliders"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Scoring Engine Weights</h5>
                    <p class="text-muted small mb-0">Configure risk parameter weights and thresholds used in credit scoring.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a href="/Settings/AuditLogs" class="text-decoration-none">
            <div class="card border-0 shadow-sm card-hover h-100">
                <div class="card-body py-4 text-center">
                    <div class="bg-warning bg-opacity-10 text-warning rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px; font-size: 1.5rem;">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Audit Log Trail</h5>
                    <p class="text-muted small mb-0">View all system activity, user action logs, and compliance records.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body py-4 text-center">
                <div class="bg-success bg-opacity-10 text-success rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px; font-size: 1.5rem;">
                    <i class="fa-solid fa-bell"></i>
                </div>
                <h5 class="fw-bold text-dark">Notification Preferences</h5>
                <p class="text-muted small mb-3">Control email and in-app alert settings per role.</p>
                <div class="d-flex justify-content-between align-items-center px-2 mb-2">
                    <span class="small text-muted">Email Alerts</span>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" checked onchange="showToast('Setting Saved','Email alerts preference updated.','success')" />
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center px-2">
                    <span class="small text-muted">In-App Toasts</span>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" checked onchange="showToast('Setting Saved','In-app notification preference updated.','success')" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

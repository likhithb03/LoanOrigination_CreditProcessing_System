<header id="topbar">
    <div class="d-flex align-items-center gap-3">
        <button class="toggle-sidebar-btn" id="toggleSidebar" aria-label="Toggle Sidebar">
            <i class="fa-solid fa-bars"></i>
        </button>
        <div class="search-bar d-none d-md-flex align-items-center bg-light px-3 py-1 rounded-pill">
            <i class="fa-solid fa-magnifying-glass text-muted me-2"></i>
            <input type="text" class="form-control border-0 bg-transparent py-1 shadow-none" placeholder="Search application number, customer, etc..." style="width: 280px; font-size: 0.85rem;" />
        </div>
    </div>
    
    <div class="d-flex align-items-center gap-3">
        <!-- Notification Dropdown -->
        <div class="dropdown">
            <button class="btn btn-link position-relative text-muted p-2 border-0 shadow-none" type="button" id="notifDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="fa-regular fa-bell fs-5"></i>
                <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-danger border border-light" id="notifBadge" style="font-size: 0.6rem;">3</span>
            </button>
            <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 py-0" aria-labelledby="notifDropdown" style="width: 320px; font-size: 0.85rem;">
                <div class="p-3 border-bottom d-flex align-items-center justify-content-between bg-light">
                    <span class="fw-bold">Notifications</span>
                    <a href="/Notification" class="text-primary text-decoration-none small">View All</a>
                </div>
                <div id="notificationList" class="list-group list-group-flush" style="max-height: 240px; overflow-y: auto;">
                    <a href="/Kyc/Verify/1001" class="list-group-item list-group-item-action p-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-semibold text-dark">KYC Uploaded</span>
                            <span class="text-muted small text-nowrap">2m ago</span>
                        </div>
                        <p class="mb-0 text-muted small">Customer 'Rajesh Kumar' uploaded verification docs.</p>
                    </a>
                    <a href="/Approval/Review/1001" class="list-group-item list-group-item-action p-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-semibold text-dark">Ready for Underwriting</span>
                            <span class="text-muted small text-nowrap">15m ago</span>
                        </div>
                        <p class="mb-0 text-muted small">Application #LOC-9844-32 has passed Credit Score thresholds.</p>
                    </a>
                    <a href="/Disbursement/Create/1001" class="list-group-item list-group-item-action p-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-semibold text-dark">Disbursement Pending</span>
                            <span class="text-muted small text-nowrap">1h ago</span>
                        </div>
                        <p class="mb-0 text-muted small">Approved application #LOC-7788-12 needs payment processing.</p>
                    </a>
                </div>
                <div class="p-2 border-top text-center bg-light">
                    <button class="btn btn-sm btn-link text-muted text-decoration-none w-100" onclick="clearNotifications()">Clear All</button>
                </div>
            </div>
        </div>

        <div class="border-start h-100 py-3 mx-1"></div>

        <!-- Profile Dropdown -->
        <div class="dropdown">
            <button class="btn btn-link d-flex align-items-center gap-2 text-decoration-none text-dark p-1 border-0 shadow-none" type="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; font-weight: 700;" id="userProfileInitials">LO</div>
                <div class="text-start d-none d-sm-block">
                    <div class="fw-semibold lh-1" style="font-size: 0.85rem;" id="userProfileName">Likhith Kumar</div>
                    <span class="text-muted small" style="font-size: 0.75rem;" id="userProfileRole">Loan Officer</span>
                </div>
                <i class="fa-solid fa-chevron-down text-muted small"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0" aria-labelledby="profileDropdown">
                <li><a class="dropdown-item py-2" href="/Settings"><i class="fa-solid fa-user-gear me-2 text-muted"></i> Account Settings</a></li>
                <li><a class="dropdown-item py-2" href="/Settings/AuditLogs"><i class="fa-solid fa-clock-rotate-left me-2 text-muted"></i> Audit Trails</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item py-2 text-danger" href="/Account/Login"><i class="fa-solid fa-right-from-bracket me-2"></i> Logout</a></li>
            </ul>
        </div>
    </div>
</header>

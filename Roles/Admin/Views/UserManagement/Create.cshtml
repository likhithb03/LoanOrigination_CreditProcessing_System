@{
    ViewData["Title"] = "Add System User";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold text-dark mb-1">Add New System User</h1>
        <p class="text-muted">Create a staff account with role-based portal access.</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3"><h5 class="fw-bold m-0">User Account Details</h5></div>
            <div class="card-body">
                <form method="post" action="/UserManagement/Create">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">User Name <span class="text-danger">*</span></label>
                            <input type="text" name="UserName" class="form-control py-2 shadow-none" placeholder="e.g. pradeep_menon" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Full Name <span class="text-danger">*</span></label>
                            <input type="text" name="FullName" class="form-control py-2 shadow-none" placeholder="e.g. Pradeep Menon" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Email Address <span class="text-danger">*</span></label>
                            <input type="email" name="Email" class="form-control py-2 shadow-none" placeholder="e.g. pradeep@locps.in" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Phone Number <span class="text-danger">*</span></label>
                            <input type="tel" name="PhoneNumber" class="form-control py-2 shadow-none" placeholder="e.g. +91 98765 43210" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Assigned Role <span class="text-danger">*</span></label>
                            <select name="assignedRole" class="form-select py-2 shadow-none" required>
                                <option value="" disabled selected>Select role</option>
                                <option value="officer">Loan Officer</option>
                                <option value="underwriter">UnderWriter</option>
                                <option value="admin">System Admin</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Initial Password <span class="text-danger">*</span></label>
                            <input type="password" name="PasswordHash" class="form-control py-2 shadow-none" placeholder="Temporary password" required minlength="6" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Confirm Password <span class="text-danger">*</span></label>
                            <input type="password" id="confirmPassword" class="form-control py-2 shadow-none" placeholder="Confirm password" required minlength="6" />
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 py-2"><i class="fa-solid fa-user-plus me-2"></i> Create User Account</button>
                        <a href="/UserManagement" class="btn btn-light border px-4 py-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
